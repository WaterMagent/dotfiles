# ~/.config/sway/config

# --- 基础设置 ---
set $mod Mod4
font pango:"JetBrains Mono Nerd Font" 10
default_border pixel 2
default_floating_border pixel 2
hide_edge_borders --i3 smart
gaps inner 10
gaps outer 5

# --- Fcitx5 环境变量配置 ---
setenv GTK_IM_MODULE fcitx
setenv QT_IM_MODULE fcitx
setenv XMODIFIERS @im=fcitx
setenv GLFW_IM_MODULE ibus # 某些应用可能需要，保持兼容
# 如果需要输入法跟随光标，确保安装了 fcitx5-frontend-gtk3/4 和 qt5-wayland/qt6-wayland
# --- 自启动 (Exec) ---
# 注意：如果 swaync 报错，请确保先执行第二步解决冲突
exec --no-startup-id swaync
exec --no-startup-id waypaper --restore
exec --no-startup-id waybar
exec --no-startup-id fcitx5 -d
# --- 输入设备 ---
input type:touchpad {
    tap enabled
    natural_scroll enabled
}

# --- 应用程序启动绑定 ---
bindsym $mod+q exec ghostty
bindsym $mod+r exec ghostty -e "rmpc"
bindsym $mod+n exec ghostty -e "nvim"
bindsym $mod+w exec waypaper
bindsym Control+$mod+w exec waypaper --random
bindsym $mod+d exec rofi -show drun
bindsym $mod+l exec swaylock
bindsym $mod+z exec brave

# --- 工作区切换 ---
bindsym $mod+1 workspace number 1
bindsym $mod+2 workspace number 2
bindsym $mod+3 workspace number 3
bindsym $mod+4 workspace number 4
bindsym $mod+5 workspace number 5
bindsym $mod+6 workspace number 6
bindsym $mod+7 workspace number 7
bindsym $mod+8 workspace number 8
bindsym $mod+9 workspace number 9
bindsym $mod+0 workspace number 10

# 移动窗口到其他工作区
bindsym Control+$mod+1 move container to workspace number 1
bindsym Control+$mod+2 move container to workspace number 2
bindsym Control+$mod+3 move container to workspace number 3
bindsym Control+$mod+4 move container to workspace number 4
bindsym Control+$mod+5 move container to workspace number 5
bindsym Control+$mod+6 move container to workspace number 6
bindsym Control+$mod+7 move container to workspace number 7
bindsym Control+$mod+8 move container to workspace number 8
bindsym Control+$mod+9 move container to workspace number 9
bindsym Control+$mod+0 move container to workspace number 10

# --- 窗口操作 ---
bindsym $mod+v floating toggle
floating_modifier $mod normal
bindsym $mod+F5 killall waybar; sleep 0.5; waybar &

# --- 改变平铺模式 ---
bindsym $mod+h layout togglesplit
bindsym $mod+t layout tabbed
bindsym $mod+s layout stacking
bindsym $mod+e layout tile

# --- 其他常用绑定 ---
bindsym $mod+Shift+q kill
bindsym $mod+Left focus left
bindsym $mod+Down focus down
bindsym $mod+Up focus up
bindsym $mod+Right focus right
bindsym $mod+Shift+Left move left
bindsym $mod+Shift+Down move down
bindsym $mod+Shift+Up move up
bindsym $mod+Shift+Right move right
bindsym $mod+f fullscreen toggle
bindsym $mod+Shift+c reload
bindsym $mod+Shift+r restart

# 【重要】已移除 colors 块，避免语法错误。
# Sway 将使用默认颜色，界面美化主要由 Waybar 和 Swaylock 负责。
