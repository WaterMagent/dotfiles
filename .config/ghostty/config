#window-height = 24
gtk-single-instance = true
#gtk-tabs-location = hidden
# custom-shader = shaders/glow.glsl
# keybinds
#keybind = global:alt+tab=toggle_tab_overview
#keybind = global:cmd+tab =toggle_tab_overview
background-opacity = 0.85
